---
export const prerender = true;
import BaseLayout from '../layouts/BaseLayout.astro';
import Terminal from '../components/Terminal.astro';
import profile from '../data/profile.json';
---

<BaseLayout title="Contact" description="Get in touch with Ade Putra Susila">
  <section class="py-8" data-cat-section="contact">
    <div class="mb-8">
      <div class="section-label">06 · contact</div>
      <h1 class="text-3xl md:text-4xl font-bold tracking-tight leading-tight">
        Let's build something<br/><span class="gradient-text">together.</span>
      </h1>
      <p class="text-base text-fg-secondary mt-3 max-w-lg">I read everything. Usually reply within a day.</p>
    </div>

    <div class="grid md:grid-cols-2 gap-6">
      <!-- Contact Info -->
      <Terminal title="contact_info.env">
        <p class="text-fg-muted font-mono text-xs mb-3">// reach out</p>
        <div class="space-y-2 font-mono text-sm">
          <p>
            <span class="text-accent">EMAIL</span> =
            <a href={`mailto:${profile.email}`} class="text-teal hover:underline">"{profile.email}"</a>
          </p>
          <p>
            <span class="text-accent">PHONE</span> =
            <a href={`tel:${profile.phone}`} class="text-teal hover:underline">"{profile.phone}"</a>
          </p>
          <p>
            <span class="text-accent">WHATSAPP</span> =
            <a href={profile.social.whatsapp} target="_blank" rel="noopener noreferrer" class="text-teal hover:underline">"{profile.whatsapp}"</a>
          </p>
          <p>
            <span class="text-accent">LINKEDIN</span> =
            <a href={profile.social.linkedin} target="_blank" rel="noopener noreferrer" class="text-teal hover:underline break-all">"linkedin.com/in/ade-putra-susila"</a>
          </p>
          <p>
            <span class="text-accent">GITHUB</span> =
            <a href={profile.social.github} target="_blank" rel="noopener noreferrer" class="text-teal hover:underline">"github.com/adeputrasusila"</a>
          </p>
          <p>
            <span class="text-accent">LOCATION</span> =
            <span class="text-fg-muted">"{profile.location}"</span>
          </p>
        </div>
      </Terminal>

      <!-- Contact Form -->
      <Terminal title="send_message.sh">
        <form id="contact-form" class="space-y-4">
          <div>
            <label class="text-fg-muted font-mono text-xs block mb-1.5">// your name</label>
            <div class="flex items-center gap-2">
              <span class="text-accent font-mono text-sm">name=</span>
              <input
                type="text"
                name="name"
                required
                class="flex-1 bg-bg-tertiary border border-border rounded-lg px-3 py-2 text-sm text-fg-primary focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent/30 transition-all"
                placeholder='"John Doe"'
              />
            </div>
          </div>

          <div>
            <label class="text-fg-muted font-mono text-xs block mb-1.5">// your email</label>
            <div class="flex items-center gap-2">
              <span class="text-accent font-mono text-sm">email=</span>
              <input
                type="email"
                name="email"
                required
                class="flex-1 bg-bg-tertiary border border-border rounded-lg px-3 py-2 text-sm text-fg-primary focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent/30 transition-all"
                placeholder='"you@example.com"'
              />
            </div>
          </div>

          <div>
            <label class="text-fg-muted font-mono text-xs block mb-1.5">// subject</label>
            <div class="flex items-center gap-2">
              <span class="text-accent font-mono text-sm">subj=</span>
              <input
                type="text"
                name="subject"
                required
                class="flex-1 bg-bg-tertiary border border-border rounded-lg px-3 py-2 text-sm text-fg-primary focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent/30 transition-all"
                placeholder='"Job Opportunity"'
              />
            </div>
          </div>

          <div>
            <label class="text-fg-muted font-mono text-xs block mb-1.5">// message</label>
            <div class="flex items-start gap-2">
              <span class="text-accent font-mono text-sm pt-2">msg=</span>
              <textarea
                name="message"
                required
                rows="4"
                class="flex-1 bg-bg-tertiary border border-border rounded-lg px-3 py-2 text-sm text-fg-primary focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent/30 transition-all resize-none"
                placeholder='"Your message here..."'
              ></textarea>
            </div>
          </div>

          <button type="submit" class="btn-primary w-full justify-center">
            execute() →
          </button>
        </form>

        <div id="form-result" class="mt-4 hidden">
          <div class="flex items-center gap-2 text-teal text-sm font-mono">
            <span class="status-dot"></span>
            message sent successfully!
          </div>
        </div>
      </Terminal>
    </div>

    <!-- Quick Actions -->
    <div class="grid grid-cols-2 md:grid-cols-5 gap-3 mt-8">
      <a href="/cv.pdf" download class="card p-4 text-center group">
        <div class="text-accent font-mono text-xs group-hover:text-teal transition-colors">dl</div>
        <div class="text-sm font-medium mt-1">Download CV</div>
      </a>
      <a href={`mailto:${profile.email}`} class="card p-4 text-center group">
        <div class="text-accent font-mono text-xs group-hover:text-teal transition-colors">mail</div>
        <div class="text-sm font-medium mt-1">Email</div>
      </a>
      <a href={profile.social.whatsapp} target="_blank" rel="noopener noreferrer" class="card p-4 text-center group">
        <div class="text-accent font-mono text-xs group-hover:text-teal transition-colors">wa</div>
        <div class="text-sm font-medium mt-1">WhatsApp</div>
      </a>
      <a href={profile.social.linkedin} target="_blank" rel="noopener noreferrer" class="card p-4 text-center group">
        <div class="text-accent font-mono text-xs group-hover:text-teal transition-colors">in</div>
        <div class="text-sm font-medium mt-1">LinkedIn</div>
      </a>
      <a href={profile.social.github} target="_blank" rel="noopener noreferrer" class="card p-4 text-center group">
        <div class="text-accent font-mono text-xs group-hover:text-teal transition-colors">gh</div>
        <div class="text-sm font-medium mt-1">GitHub</div>
      </a>
    </div>
  </section>
</BaseLayout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const result = document.getElementById('form-result');
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    result?.classList.remove('hidden');
    form.reset();
    setTimeout(() => result?.classList.add('hidden'), 5000);
  });
</script>
