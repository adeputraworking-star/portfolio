---
export const prerender = true;
import BaseLayout from '../layouts/BaseLayout.astro';

const experiences = [
  {
    id: 'pegadaian',
    role: 'Fullstack Engineer',
    company: 'PT. Pegadaian',
    shortName: 'Pegadaian',
    industry: 'Fintech',
    period: 'Dec 2025 — Present',
    description: 'Handle Penetration Testing for Monitoring Environment Application and SAPA CMS. Create Auditor Application based on user needs on IAIS Application and handle revamp design on Customer Feedback Website and Backend.',
    tech: ['NestJS', 'Springboot', 'Vue', 'TypeScript', 'PostgreSQL', 'PHP', 'Prisma', 'Microservices'],
  },
  {
    id: 'dataintegrasi',
    role: 'Backend Engineer',
    company: 'PT. Data Integrasi Inovasi',
    shortName: 'Data Integrasi',
    industry: 'Healthcare',
    period: 'Aug 2025 — Nov 2025',
    description: 'Improved document processing API by optimizing over 40 logic components. Integrated WhatsApp Live Chat using Qiscus API for real-time chat. Implemented Digital e-Signature (TTE) integration with vendors Peruri and Tilaka.',
    tech: ['Node.js', 'NestJS', 'MongoDB', 'PostgreSQL', 'Socket.IO', 'Sequelize', 'Prisma'],
  },
  {
    id: 'amp',
    role: 'Fullstack Engineer',
    company: 'PT. AMP',
    shortName: 'AMP',
    industry: 'Gaming',
    period: 'Mar 2024 — May 2024',
    description: 'Created a dashboard for monitoring the system and topping up certain games integrated with third-party application. Created API that meets business demands, ensuring reliability, robustness, security, and high performance.',
    tech: ['React', 'Node.js', 'PostgreSQL', 'Sequelize'],
  },
  {
    id: 'bumiamartha',
    role: 'Fullstack Engineer',
    company: 'PT. Bumi Amartha Teknologi Mandiri',
    shortName: 'Bumi Amartha',
    industry: 'Banking',
    period: 'Dec 2022 — Dec 2023',
    description: 'Maintenance web application for Regulatory Reporting (ANTASENA, SLIK, SCV, APOLO). Built innovative custom export excel features and improved import excel performance from 1 hour to 2 mins. Led team of 2 junior software engineers.',
    tech: ['React', '.NET Core', 'IIS', 'SQL Server', 'Microservices'],
  },
  {
    id: 'kelola',
    role: 'Fullstack Engineer',
    company: 'PT. Kelola Teknologi Digital',
    shortName: 'Kelola Tech',
    industry: 'Education',
    period: 'Nov 2021 — Dec 2022',
    description: 'Maintenance web application for Web Video Conference. Improved backend structure, implementing file management system, and maintenance previous features.',
    tech: ['React', 'Node.js', 'BigBlueButton'],
  },
  {
    id: 'inovasi',
    role: 'Fullstack Engineer',
    company: 'PT. Inovasi Solusi International',
    shortName: 'Inovasi Solusi',
    industry: 'Fintech',
    period: 'Feb 2019 — Nov 2021',
    description: 'Created trading system from scratch, refactoring code, and optimizing performance. Built real-time dashboard data from millions of stock prices using WebSocket.',
    tech: ['React', 'Node.js', 'Microservices', 'Docker', 'Kubernetes', 'Elasticsearch'],
  }
];
---

<BaseLayout title="Experience" description="Career timeline of Ade Putra Susila">
  <section class="py-8" data-cat-section="experience">
    <div class="mb-8">
      <div class="section-label">04 · career</div>
      <h1 class="text-3xl md:text-4xl font-bold tracking-tight">Where I've <span class="gradient-text">been.</span></h1>
    </div>

    <!-- Tab Bar -->
    <div class="flex gap-1 overflow-x-auto pb-1 mb-6 scrollbar-hide">
      {experiences.map((exp, i) => (
        <button
          data-exp-tab={exp.id}
          class={`exp-tab whitespace-nowrap px-4 py-2 text-sm font-medium rounded-lg transition-all cursor-pointer ${
            i === 0
              ? 'bg-accent-soft text-accent border border-border-accent'
              : 'text-fg-muted hover:text-fg-primary hover:bg-bg-tertiary border border-transparent'
          }`}
        >
          {exp.shortName}
        </button>
      ))}
    </div>

    <!-- Experience Panels -->
    {experiences.map((exp, i) => (
      <div
        data-exp-panel={exp.id}
        class={`card p-6 transition-all duration-300 ${i === 0 ? '' : 'hidden'}`}
      >
        <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-2 mb-4">
          <div>
            <h2 class="text-lg font-bold text-fg-primary">{exp.role}</h2>
            <p class="text-accent text-sm font-medium">@ {exp.company}</p>
            <span class="text-[0.625rem] font-mono text-teal uppercase tracking-wider">{exp.industry}</span>
          </div>
          <span class="text-xs font-mono text-fg-muted bg-bg-tertiary px-3 py-1 rounded-md whitespace-nowrap self-start">{exp.period}</span>
        </div>
        <p class="text-sm text-fg-secondary leading-relaxed mb-4">{exp.description}</p>
        <div class="flex flex-wrap gap-1.5">
          {exp.tech.map((t: string) => (
            <span class="tech-chip">{t}</span>
          ))}
        </div>
      </div>
    ))}

    <!-- Timeline Overview -->
    <div class="mt-8">
      <p class="text-xs font-mono text-fg-muted mb-4 uppercase tracking-widest">Timeline</p>
      <div class="card p-6">
        {experiences.map((exp) => (
          <div class="timeline-item">
            <div class="font-semibold text-sm text-fg-primary">{exp.role}</div>
            <div class="text-sm text-accent mt-0.5">@ {exp.company}</div>
            <div class="text-xs text-fg-muted font-mono mt-0.5">{exp.period}</div>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const tabs = document.querySelectorAll<HTMLButtonElement>('[data-exp-tab]');
  const panels = document.querySelectorAll<HTMLElement>('[data-exp-panel]');

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const targetId = tab.dataset.expTab;

      tabs.forEach((t) => {
        t.classList.remove('bg-accent-soft', 'text-accent', 'border-border-accent');
        t.classList.add('text-fg-muted', 'border-transparent');
      });
      tab.classList.add('bg-accent-soft', 'text-accent', 'border-border-accent');
      tab.classList.remove('text-fg-muted', 'border-transparent');

      panels.forEach((p) => {
        if (p.dataset.expPanel === targetId) {
          p.classList.remove('hidden');
        } else {
          p.classList.add('hidden');
        }
      });
    });
  });
</script>

<style>
  .scrollbar-hide::-webkit-scrollbar { display: none; }
  .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
</style>
