---
import profile from '../data/profile.json';
---

<footer class="border-t border-border mt-16 py-10">
  <div class="container mx-auto px-4 sm:px-6 max-w-5xl">
    <div class="terminal-card">
      <div class="terminal-card-header">
        <span class="terminal-dot terminal-dot-red"></span>
        <span class="terminal-dot terminal-dot-yellow"></span>
        <span class="terminal-dot terminal-dot-green"></span>
        <span class="terminal-card-title">footer.sh</span>
      </div>
      <div class="terminal-card-body font-mono text-xs space-y-1.5">
        <p class="text-fg-muted mb-3">// social links</p>
        <p>
          <span class="text-accent">export</span>
          <span class="text-amber ml-1">LINKEDIN</span>=
          <a href={profile.social.linkedin} target="_blank" rel="noopener noreferrer" class="text-teal hover:underline">
            "{profile.social.linkedin}"
          </a>
        </p>
        <p>
          <span class="text-accent">export</span>
          <span class="text-amber ml-1">GITHUB</span>=
          <a href={profile.social.github} target="_blank" rel="noopener noreferrer" class="text-teal hover:underline">
            "{profile.social.github}"
          </a>
        </p>
        <p>
          <span class="text-accent">export</span>
          <span class="text-amber ml-1">EMAIL</span>=
          <a href={profile.social.email} class="text-teal hover:underline">
            "{profile.email}"
          </a>
        </p>
        <div class="pt-3 mt-3 border-t border-border text-fg-muted">
          <p>// built with Astro & Tailwind</p>
          <p>// &copy; {new Date().getFullYear()} {profile.name}</p>
        </div>
      </div>
    </div>
  </div>
</footer>
