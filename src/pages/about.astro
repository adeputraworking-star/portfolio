---
export const prerender = true;
import BaseLayout from '../layouts/BaseLayout.astro';
import Terminal from '../components/Terminal.astro';
import profile from '../data/profile.json';
---

<BaseLayout title="About" description="Learn more about Ade Putra Susila, Fullstack Engineer from Indonesia">
  <section class="py-8">
    <div class="mb-8">
      <div class="section-label">01 · about</div>
      <h1 class="text-3xl md:text-4xl font-bold tracking-tight">Focused on shipping,<br/><span class="gradient-text">not sprinting.</span></h1>
    </div>

    <div data-cat-section="about">
      <Terminal title="about.txt" class="mb-8">
        <p class="text-fg-muted font-mono text-xs mb-3">// who am i?</p>
        <p class="text-fg-secondary text-sm leading-relaxed mb-6">{profile.bio}</p>

        <p class="text-fg-muted font-mono text-xs mb-3">// personal info</p>
        <div class="space-y-1 font-mono text-sm">
          <p><span class="text-accent">name</span> = <span class="text-teal">"{profile.name}"</span></p>
          <p><span class="text-accent">title</span> = <span class="text-teal">"{profile.title}"</span></p>
          <p><span class="text-accent">location</span> = <span class="text-fg-muted">"{profile.location}"</span></p>
          <p><span class="text-accent">experience</span> = <span class="text-amber">"5 years"</span></p>
        </div>
      </Terminal>
    </div>

    <div data-cat-section="education">
      <Terminal title="education.log" class="mb-8">
        <p class="text-fg-muted font-mono text-xs mb-3">// education</p>
        <div class="space-y-1 font-mono text-sm">
          <p><span class="text-accent">institution</span> = <span class="text-amber">"{profile.education.institution}"</span></p>
          <p><span class="text-accent">degree</span> = <span class="text-teal">"{profile.education.degree}"</span></p>
          <p><span class="text-accent">period</span> = <span class="text-fg-muted">"{profile.education.period}"</span></p>
          <p><span class="text-accent">gpa</span> = <span class="text-amber">"{profile.education.gpa}"</span></p>
        </div>
      </Terminal>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-3" data-cat-section="stats">
      {[
        { n: '5+', l: 'Years Experience' },
        { n: '5', l: 'Companies' },
        { n: '15+', l: 'Technologies' },
        { n: '5', l: 'Industries' },
      ].map(({ n, l }) => (
        <div class="card p-5 text-center">
          <div class="text-3xl font-bold gradient-text tracking-tight">{n}</div>
          <div class="text-[0.625rem] text-fg-muted font-mono uppercase tracking-wider mt-1">{l}</div>
        </div>
      ))}
    </div>
  </section>
</BaseLayout>
