---
// CatGuide — Cat mascot with scroll-driven narration, auto voice, and page-by-page guided tour.
// Scroll-triggers via data-cat-section attributes. Guides users to the next page automatically.
---

<!-- Cat Speech Bubble -->
<div id="cat-bubble" class="fixed bottom-[130px] right-4 z-50 transition-all duration-300 origin-bottom-right pointer-events-none" style="max-width: 320px; min-width: 260px; contain: layout style; display: none;">
  <div class="glass rounded-xl overflow-hidden shadow-2xl" style="box-shadow: 0 0 30px rgba(124,158,255,0.15), 0 8px 32px rgba(0,0,0,0.4);">
    <div class="flex items-center gap-1.5 px-3 py-2 border-b border-white/5" style="background: rgba(255,255,255,0.03);">
      <span class="w-2 h-2 rounded-full bg-dot-red"></span>
      <span class="w-2 h-2 rounded-full bg-dot-yellow"></span>
      <span class="w-2 h-2 rounded-full bg-dot-green"></span>
      <span id="cat-bubble-title" class="flex-1 text-center text-[0.625rem] font-mono text-fg-secondary">neko@guide:~$</span>
    </div>
    <div class="px-3.5 py-3 min-h-[50px]">
      <span id="cat-bubble-text" class="text-[0.8125rem] text-fg-primary leading-relaxed"></span>
      <span id="cat-cursor" class="animate-blink font-mono text-accent font-bold">_</span>
    </div>
    <!-- Next page button -->
    <div id="cat-nav" class="hidden px-3.5 pb-3 pt-1">
      <button id="cat-next-page" class="w-full btn-primary text-xs justify-center py-2 cursor-pointer">
        Next page →
      </button>
    </div>
  </div>
  <!-- Arrow -->
  <div class="absolute -bottom-1.5 right-8 w-3 h-3 rotate-45 glass border-r border-b border-white/8"></div>
</div>

<!-- Voice Toggle -->
<button
  id="cat-voice-btn"
  class="fixed bottom-[130px] right-[calc(1rem+82px)] z-50 glass rounded-lg px-2.5 py-1.5 text-[0.625rem] font-mono hover:text-accent transition-colors cursor-pointer"
  style="color: #52d1a4;"
  title="Toggle cat voice"
  aria-label="Toggle cat voice narration"
>
  🔊 <span id="cat-voice-status">ON</span>
</button>

<!-- Cat Character -->
<div id="cat-guide" class="fixed bottom-4 right-4 z-50 cursor-pointer transition-transform duration-300 hover:scale-105" style="filter: drop-shadow(0 0 20px rgba(124,158,255,0.2));">
  <div class="animate-float">
    <svg viewBox="0 0 180 200" width="80" height="90">
      <defs>
        <linearGradient id="cat-body-grad" x1="0" y1="0" x2="0" y2="1">
          <stop offset="0" stop-color="#4a5160"/>
          <stop offset="1" stop-color="#2d3240"/>
        </linearGradient>
        <linearGradient id="cat-hood-grad" x1="0" y1="0" x2="0" y2="1">
          <stop offset="0" stop-color="#2d3240"/>
          <stop offset="1" stop-color="#181b23"/>
        </linearGradient>
      </defs>
      <!-- Hoodie -->
      <path d="M30 130 Q30 90 90 85 Q150 90 150 130 L150 180 L30 180 Z" fill="url(#cat-hood-grad)"/>
      <!-- Ears -->
      <path d="M55 65 L50 30 L75 55 Z" fill="url(#cat-body-grad)"/>
      <path d="M125 65 L130 30 L105 55 Z" fill="url(#cat-body-grad)"/>
      <path d="M58 55 L56 42 L68 52 Z" fill="#e89a96" opacity="0.8"/>
      <path d="M122 55 L124 42 L112 52 Z" fill="#e89a96" opacity="0.8"/>
      <!-- Head -->
      <ellipse cx="90" cy="85" rx="48" ry="42" fill="url(#cat-body-grad)"/>
      <!-- Eyes -->
      <ellipse cx="72" cy="82" rx="8" ry="10" fill="#0a0b10"/>
      <ellipse cx="108" cy="82" rx="8" ry="10" fill="#0a0b10"/>
      <circle cx="72" cy="80" r="5" fill="#7c9eff">
        <animate attributeName="r" values="5;4;5" dur="3s" repeatCount="indefinite"/>
      </circle>
      <circle cx="108" cy="80" r="5" fill="#7c9eff">
        <animate attributeName="r" values="5;4;5" dur="3s" repeatCount="indefinite" begin="0.5s"/>
      </circle>
      <circle cx="70" cy="78" r="1.5" fill="#fff"/>
      <circle cx="106" cy="78" r="1.5" fill="#fff"/>
      <!-- Nose + Mouth -->
      <path d="M86 98 L94 98 L90 104 Z" fill="#e89a96"/>
      <path d="M90 104 Q85 110 80 108 M90 104 Q95 110 100 108" stroke="#1a1d26" stroke-width="1.5" fill="none" stroke-linecap="round"/>
      <!-- Whiskers -->
      <g stroke="#9aa0ac" stroke-width="0.8" opacity="0.5">
        <path d="M45 95 L68 98 M45 102 L68 103"/>
        <path d="M135 95 L112 98 M135 102 L112 103"/>
      </g>
      <!-- Laptop -->
      <rect x="55" y="150" width="70" height="22" rx="3" fill="#181b23" stroke="#2d3240"/>
      <rect x="60" y="154" width="60" height="14" rx="1" fill="#0a0b10"/>
      <rect x="63" y="157" width="28" height="1.5" fill="#52d1a4" opacity="0.7"/>
      <rect x="63" y="160" width="20" height="1.5" fill="#7c9eff" opacity="0.7"/>
      <rect x="63" y="163" width="34" height="1.5" fill="#52d1a4" opacity="0.5"/>
      <!-- Paws -->
      <ellipse cx="45" cy="160" rx="10" ry="8" fill="url(#cat-body-grad)"/>
      <ellipse cx="135" cy="160" rx="10" ry="8" fill="url(#cat-body-grad)"/>
    </svg>
  </div>
</div>

<script>
  // ── Page navigation order for guided tour ──
  const pageOrder = ['/', '/about', '/skills', '/projects', '/experience', '/contact', '/blog'];
  const pageNames: Record<string, string> = {
    '/': 'About', '/about': 'Skills', '/skills': 'Projects',
    '/projects': 'Experience', '/experience': 'Contact', '/contact': 'Blog',
  };

  // ── Cat narration lines per section ──
  const catLines: Record<string, string> = {
    'hero':       "hey! i'm neko, your guide. scroll down and i'll walk you through ade's work!",
    'highlights': "some cool stuff ade has done. the excel one is wild.",
    'about':      "this is ade. self-taught, 5+ years, always shipping.",
    'education':  "binus grad! not bad for a self-taught dev.",
    'stats':      "numbers go brrr. five years across five industries.",
    'skills':     "his skill tree is pretty deep. react, node, .net, springboot, vue...",
    'projects':   "real production systems across fintech, healthcare, banking, gaming, and education.",
    'experience': "career timeline. from startup to enterprise, each one was a level-up.",
    'blog':       "he writes sometimes. good reading while i nap on your keyboard.",
    'contact':    "wanna reach out? he reads everything. i read half.",
  };

  const bubble = document.getElementById('cat-bubble');
  const bubbleText = document.getElementById('cat-bubble-text');
  const catCursor = document.getElementById('cat-cursor');
  const catGuideEl = document.getElementById('cat-guide');
  const voiceBtn = document.getElementById('cat-voice-btn');
  const voiceStatus = document.getElementById('cat-voice-status');
  const catNav = document.getElementById('cat-nav');
  const catNextBtn = document.getElementById('cat-next-page');

  let voiceOn = true; // Auto ON by default
  let currentLine = '';
  let typeTimer: ReturnType<typeof setInterval> | null = null;
  let bubbleVisible = false;
  let debounceTimer: ReturnType<typeof setTimeout> | null = null;
  let seenSections = new Set<string>();
  let hasUserActivation = false;

  // Track user activation so we only call speechSynthesis after interaction
  function markActivated() {
    hasUserActivation = true;
    document.removeEventListener('click', markActivated);
    document.removeEventListener('keydown', markActivated);
    document.removeEventListener('touchstart', markActivated);
  }
  document.addEventListener('click', markActivated);
  document.addEventListener('keydown', markActivated);
  document.addEventListener('touchstart', markActivated);

  // ── Get next page ──
  function getNextPage(): string | null {
    let path = window.location.pathname;
    if (path.endsWith('/') && path !== '/') path = path.slice(0, -1);
    const idx = pageOrder.indexOf(path);
    if (idx === -1 || idx >= pageOrder.length - 1) return null;
    return pageOrder[idx + 1];
  }

  function getNextPageLabel(): string {
    let path = window.location.pathname;
    if (path.endsWith('/') && path !== '/') path = path.slice(0, -1);
    return pageNames[path] || 'Next';
  }

  // ── Show / hide bubble ──
  let fontsReady = false;

  function showBubble() {
    if (!bubble || !fontsReady) return;
    bubble.style.display = '';
    bubble.classList.remove('pointer-events-none');
    bubble.style.opacity = '1';
    bubble.style.transform = 'scale(1)';
    bubbleVisible = true;
  }
  function hideBubble() {
    if (!bubble) return;
    bubble.classList.add('pointer-events-none');
    bubble.style.opacity = '0';
    bubble.style.transform = 'scale(0.9)';
    setTimeout(() => {
      if (!bubbleVisible) bubble.style.display = 'none';
    }, 300);
    bubbleVisible = false;
  }

  // ── Show/hide next page button ──
  function updateNavButton() {
    if (!catNav || !catNextBtn) return;
    const next = getNextPage();
    if (next) {
      catNextBtn.textContent = `Next: ${getNextPageLabel()} →`;
      catNav.classList.remove('hidden');
    } else {
      catNav.classList.add('hidden');
    }
  }

  // ── Typewriter ──
  function typeText(text: string) {
    if (typeTimer) clearInterval(typeTimer);
    if (!bubbleText || !catCursor) return;
    bubbleText.textContent = '';
    catCursor.style.display = 'inline';
    let i = 0;
    typeTimer = setInterval(() => {
      if (i < text.length) {
        bubbleText.textContent = text.slice(0, ++i);
      } else {
        if (typeTimer) clearInterval(typeTimer);
        catCursor.style.display = 'none';
        updateNavButton();
      }
    }, 24);
  }

  // ── TTS ──
  function speak(text: string) {
    if (!voiceOn || !hasUserActivation || !('speechSynthesis' in window)) return;
    window.speechSynthesis.cancel();
    setTimeout(() => {
      const u = new SpeechSynthesisUtterance(text);
      u.rate = 1.05;
      u.pitch = 1.4;
      u.volume = 0.85;
      const voices = window.speechSynthesis.getVoices();
      const pref = voices.find(v => /samantha|zira|google us/i.test(v.name)) || voices[0];
      if (pref) u.voice = pref;
      window.speechSynthesis.speak(u);
    }, 80);
  }

  // ── Set line (debounced) ──
  function setLine(key: string) {
    const text = catLines[key] || catLines['hero'];
    if (text === currentLine) return;
    if (debounceTimer) clearTimeout(debounceTimer);
    debounceTimer = setTimeout(() => {
      currentLine = text;
      seenSections.add(key);
      showBubble();
      typeText(text);
      speak(text);
    }, 150);
  }

  // ── Scroll observer ──
  function initScrollObserver() {
    const sections = document.querySelectorAll('[data-cat-section]');
    if (sections.length === 0) return;

    const observer = new IntersectionObserver((entries) => {
      const visible = entries
        .filter(e => e.isIntersecting)
        .sort((a, b) => b.intersectionRatio - a.intersectionRatio);
      if (visible[0]) {
        const key = (visible[0].target as HTMLElement).dataset.catSection || 'hero';
        setLine(key);
      }
    }, {
      rootMargin: '-20% 0px -20% 0px',
      threshold: [0, 0.25, 0.5]
    });

    sections.forEach(el => observer.observe(el));
  }

  // ── Click cat to toggle ──
  catGuideEl?.addEventListener('click', () => {
    if (bubbleVisible) hideBubble();
    else { showBubble(); typeText(currentLine || catLines['hero']); }
  });

  // ── Next page button ──
  catNextBtn?.addEventListener('click', () => {
    const next = getNextPage();
    if (next) window.location.href = next;
  });

  // ── Voice toggle ──
  voiceBtn?.addEventListener('click', () => {
    voiceOn = !voiceOn;
    if (voiceStatus) voiceStatus.textContent = voiceOn ? 'ON' : 'OFF';
    if (voiceBtn) voiceBtn.style.color = voiceOn ? '#52d1a4' : '';
    if (voiceOn && currentLine) speak(currentLine);
    else if ('speechSynthesis' in window) window.speechSynthesis.cancel();
  });

  // ── Get initial section key for current page ──
  function getPageKey(): string {
    const path = window.location.pathname.replace(/^\/|\/$/g, '');
    // Home page → 'hero', other pages → page name (about, skills, etc.)
    return path || 'hero';
  }

  // ── Init ──
  document.addEventListener('DOMContentLoaded', () => {
    if ('speechSynthesis' in window) {
      window.speechSynthesis.getVoices();
      window.speechSynthesis.onvoiceschanged = () => window.speechSynthesis.getVoices();
    }
    initScrollObserver();

    // Wait for fonts to finish loading before showing the bubble to avoid CLS
    document.fonts.ready.then(() => {
      fontsReady = true;
      setTimeout(() => setLine(getPageKey()), 300);
    });
  });

  // Re-init on Astro page transitions
  document.addEventListener('astro:page-load', () => {
    seenSections.clear();
    currentLine = ''; // Reset so the new page line plays
    initScrollObserver();
    document.fonts.ready.then(() => {
      fontsReady = true;
      setTimeout(() => setLine(getPageKey()), 300);
    });
  });
</script>

<style>
  @media (max-width: 768px) {
    #cat-guide { transform: scale(0.85); transform-origin: bottom right; }
    #cat-bubble { max-width: 260px; bottom: 110px !important; right: 0.5rem !important; }
    #cat-voice-btn { display: none; }
  }
</style>
