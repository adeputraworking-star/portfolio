---
export const prerender = true;
import BaseLayout from '../layouts/BaseLayout.astro';
import ExperienceItem from '../components/ExperienceItem.astro';

const experiences = [
  {
    role: 'Senior Fullstack Engineer',
    company: 'PT Kazee Digital Indonesia',
    period: 'Nov 2023 — Present',
    description: 'Building healthcare information systems (SIMRS, HRIS) with real-time chat, e-signature integration, and complex multi-module architectures.'
  },
  {
    role: 'Fullstack Developer',
    company: 'PT Bareksa Portal Investasi',
    period: 'Jul 2022 — Nov 2023',
    description: 'Developed real-time trading dashboards processing millions of stock price updates via WebSocket and Elasticsearch.'
  },
  {
    role: 'Software Engineer',
    company: 'PT Sigma Cipta Caraka (Telkomsigma)',
    period: 'Feb 2021 — Jul 2022',
    description: 'Built banking regulatory reporting systems. Optimized Excel import from 1 hour to 2 minutes for 30,000 rows.'
  },
  {
    role: 'Software Engineer',
    company: 'PT Telekomunikasi Indonesia (Telkom)',
    period: 'Aug 2020 — Feb 2021',
    description: 'Developed video conferencing and file management systems for educational platforms.'
  },
  {
    role: 'Junior Developer',
    company: 'PT Digital Kode Teknologi',
    period: 'Sep 2019 — Jul 2020',
    description: 'Built game top-up monitoring dashboards with third-party provider integrations.'
  }
];
---

<BaseLayout title="Experience" description="Career timeline of Ade Putra Susila">
  <section class="py-8" data-cat-section="experience">
    <div class="mb-8">
      <div class="section-label">04 · career</div>
      <h1 class="text-3xl md:text-4xl font-bold tracking-tight">Where I've <span class="gradient-text">been.</span></h1>
    </div>

    <div class="card p-6">
      {experiences.map((exp) => (
        <ExperienceItem
          role={exp.role}
          company={exp.company}
          period={exp.period}
          description={exp.description}
        />
      ))}
    </div>
  </section>
</BaseLayout>
