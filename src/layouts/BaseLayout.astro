---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CatGuide from '../components/CatGuide.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Fullstack Engineer with 5+ years of experience building scalable web applications' } = Astro.props;
const fullTitle = `${title} | Ade Putra Susila`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="author" content="Ade Putra Susila" />
    <meta name="keywords" content="Fullstack Engineer, React, Node.js, .NET Core, Web Developer, Indonesia" />
    <meta name="theme-color" content="#0a0b10" />

    <!-- Open Graph -->
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />

    <!-- PWA -->
    <link rel="manifest" href="/manifest.json" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <link rel="apple-touch-icon" href="/icons/icon-192.png" />

    <!-- Fonts — non-render-blocking with media swap -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600;700&display=swap"
      rel="stylesheet"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600;700&display=swap"
        rel="stylesheet"
      />
    </noscript>

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <title>{fullTitle}</title>
  </head>
  <body class="min-h-screen bg-bg-primary text-fg-primary relative overflow-x-hidden">
    <!-- Ambient background -->
    <div class="bg-video-wrapper" aria-hidden="true">
      <video id="bg-video" class="bg-video" autoplay loop muted playsinline disablepictureinpicture>
        <source src="/bg.webm" type="video/webm" />
        <source src="/bg.mp4" type="video/mp4" />
      </video>
    </div>
    <div class="bg-grid" aria-hidden="true"></div>
    <div class="ambient-orb ambient-orb-1" aria-hidden="true"></div>
    <div class="ambient-orb ambient-orb-2" aria-hidden="true"></div>

    <div class="relative z-10">
      <Header />
      <main class="container mx-auto px-4 sm:px-6 py-8 max-w-5xl">
        <slot />
      </main>
      <Footer />
    </div>

    <!-- Cat Guide + Narration -->
    <CatGuide />

    <!-- Deferred: lazy-load GIF background and paw trail after page interactive -->
    <script is:inline>
      // Lazy-load the background video after page loads
      window.addEventListener('load', function() {
        var video = document.getElementById('bg-video');
        if (video) video.play().catch(function(){});
      });

      // Paw click trail
      document.addEventListener('click', function(e) {
        var paw = document.createElement('div');
        paw.className = 'paw-print';
        paw.innerHTML = "<svg xmlns='http://www.w3.org/2000/svg' width='20' height='24' viewBox='0 0 24 28'><ellipse cx='12' cy='18' rx='5' ry='4' fill='#7c9eff' opacity='0.7'/><circle cx='7' cy='10' r='2.5' fill='#7c9eff' opacity='0.6'/><circle cx='12' cy='7' r='2.5' fill='#7c9eff' opacity='0.6'/><circle cx='17' cy='10' r='2.5' fill='#7c9eff' opacity='0.6'/></svg>";
        paw.style.left = (e.clientX - 10) + 'px';
        paw.style.top = (e.clientY - 12) + 'px';
        document.body.appendChild(paw);
        setTimeout(function() { paw.remove(); }, 800);
      });

      // Service Worker
      if ('serviceWorker' in navigator) {
        navigator.serviceWorker.register('/sw.js').catch(function(){});
      }
    </script>
  </body>
</html>
