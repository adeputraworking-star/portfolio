---
export const prerender = true;
import BaseLayout from '../layouts/BaseLayout.astro';
import Terminal from '../components/Terminal.astro';

const projects = [
  {
    name: 'simrs-hris-system',
    description: 'Healthcare information system including SIMRS, HRIS, and Unit Cost modules with real-time chat and e-signature integration',
    tech: ['Node.js', 'NestJS', 'MongoDB', 'PostgreSQL', 'Socket.IO', 'Prisma'],
    type: 'Healthcare',
    highlight: 'Digital e-Signature (TTE) integration',
    color: '#7c9eff'
  },
  {
    name: 'trading-system',
    description: 'Real-time trading system with live stock price dashboard processing millions of data points',
    tech: ['React JS', 'Node.js', 'WebSocket', 'Elasticsearch', 'Docker'],
    type: 'Fintech',
    highlight: 'Real-time dashboard with WebSocket',
    color: '#52d1a4'
  },
  {
    name: 'regulatory-reporting',
    description: 'Banking regulatory reporting system for ANTASENA, SLIK, SCV, and APOLO modules',
    tech: ['React JS', '.NET Core', 'SQL Server', 'Microservices'],
    type: 'Banking',
    highlight: 'Excel import: 1hr → 2min',
    color: '#f472b6'
  },
  {
    name: 'video-conference',
    description: 'Web-based video conference and management system for educational purposes',
    tech: ['React JS', 'Node.js', 'BigBlueButton'],
    type: 'Education',
    highlight: 'File management system',
    color: '#fbbf24'
  },
  {
    name: 'game-topup-monitor',
    description: 'Dashboard for monitoring and top-up services integrated with third-party game providers',
    tech: ['React JS', 'Node.js', 'PostgreSQL', 'Sequelize'],
    type: 'Gaming',
    highlight: 'Third-party integration',
    color: '#a78bfa'
  }
];
---

<BaseLayout title="Projects" description="Portfolio of projects built by Ade Putra Susila">
  <section class="py-8" data-cat-section="projects">
    <div class="mb-8">
      <div class="section-label">03 · work</div>
      <h1 class="text-3xl md:text-4xl font-bold tracking-tight">Selected <span class="gradient-text">projects.</span></h1>
    </div>

    <div class="grid md:grid-cols-2 gap-4">
      {projects.map((project) => (
        <div class="card relative overflow-hidden">
          <!-- Top gradient line -->
          <div class="absolute top-0 left-0 right-0 h-[1px]" style={`background: linear-gradient(90deg, transparent, ${project.color}, transparent)`}></div>

          <div class="p-5">
            <div class="flex items-start justify-between mb-3">
              <div>
                <span class="text-[0.625rem] font-mono font-semibold uppercase tracking-wider text-fg-muted">{project.type}</span>
                <h3 class="font-mono text-base font-semibold mt-1" style={`color: ${project.color}`}>{project.name}</h3>
              </div>
            </div>

            <p class="text-sm text-fg-secondary leading-relaxed mb-4">{project.description}</p>

            <div class="flex flex-wrap gap-1.5 mb-4">
              {project.tech.map((t) => (
                <span class="tech-chip">{t}</span>
              ))}
            </div>

            <div class="pt-3 border-t border-border">
              <span class="text-[0.625rem] font-mono text-fg-muted uppercase tracking-wider">Highlight</span>
              <p class="text-sm text-amber mt-0.5">{project.highlight}</p>
            </div>
          </div>
        </div>
      ))}
    </div>

    <Terminal title="note.txt" class="mt-8">
      <p class="text-fg-muted font-mono text-xs">// professional projects — source code is proprietary</p>
      <p class="text-teal font-mono text-xs mt-1">// for open-source work, check my GitHub profile</p>
    </Terminal>
  </section>
</BaseLayout>
