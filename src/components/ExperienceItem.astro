---
interface Props {
  role: string;
  company: string;
  period: string;
  description?: string;
}

const { role, company, period, description } = Astro.props;
---

<div class="timeline-item">
  <div class="font-semibold text-sm text-fg-primary">{role}</div>
  <div class="text-sm text-accent mt-0.5">@ {company}</div>
  <div class="text-xs text-fg-muted font-mono mt-0.5">{period}</div>
  {description && <p class="text-sm text-fg-secondary mt-2 leading-relaxed">{description}</p>}
</div>
