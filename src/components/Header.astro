---
const navItems = [
  { name: 'home', path: '/' },
  { name: 'about', path: '/about' },
  { name: 'skills', path: '/skills' },
  { name: 'projects', path: '/projects' },
  { name: 'experience', path: '/experience' },
  { name: 'blog', path: '/blog' },
  { name: 'contact', path: '/contact' },
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 border-b border-border" style="background: rgba(10,11,16,0.85); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);">
  <nav class="container mx-auto px-4 sm:px-6 max-w-5xl">
    <div class="flex items-center justify-between h-14">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2.5 group">
        <div class="w-7 h-7 rounded-lg gradient-bg flex items-center justify-center text-xs font-bold text-bg-primary transition-shadow group-hover:shadow-[0_0_16px_rgba(124,158,255,0.4)]">
          a
        </div>
        <span class="font-semibold text-sm tracking-tight text-fg-primary">ade<span class="text-fg-muted">.dev</span></span>
      </a>

      <!-- Desktop Navigation -->
      <ul class="hidden md:flex items-center gap-1">
        {navItems.map((item) => (
          <li>
            <a
              href={item.path}
              class={`px-3 py-1.5 text-sm rounded-md transition-all font-medium ${
                currentPath === item.path || (item.path !== '/' && currentPath.startsWith(item.path))
                  ? 'text-accent bg-accent-soft'
                  : 'text-fg-muted hover:text-fg-primary hover:bg-bg-tertiary'
              }`}
            >
              {item.name}
            </a>
          </li>
        ))}
        <li>
          <span class="ml-2 flex items-center gap-1.5 text-xs font-mono text-teal">
            <span class="status-dot"></span>
            available
          </span>
        </li>
      </ul>

      <!-- Mobile Menu Button -->
      <button
        id="mobile-menu-btn"
        class="md:hidden p-2 text-fg-primary hover:bg-bg-tertiary rounded-lg transition-colors"
        aria-label="Toggle menu"
      >
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
          <path d="M3 6h14M3 10h14M3 14h14" />
        </svg>
      </button>
    </div>

    <!-- Mobile Navigation -->
    <div id="mobile-menu" class="hidden md:hidden pb-4">
      <ul class="space-y-1">
        {navItems.map((item) => (
          <li>
            <a
              href={item.path}
              class={`block px-3 py-2 text-sm rounded-lg transition-all ${
                currentPath === item.path
                  ? 'text-accent bg-accent-soft'
                  : 'text-fg-muted hover:text-fg-primary hover:bg-bg-tertiary'
              }`}
            >
              {item.name}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </nav>
</header>

<script>
  const menuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  menuBtn?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
  });
</script>
